{
  "mcp": {
    "notes-dev-server": {
      "type": "local",
      "command": ["go", "run", "./notes-app/server/cmd/server"],
      "enabled": true,
      "description": "Local development server for notes app"
    }
  },
  "rules": {
    "paths": ["./notes-app/RULES.md"]
  },
  "instructions": ["./notes-app/RULES.md"],
  "permission": {
    "bash": {
      "cd notes-app && go test ./...": "allow",
      "cd notes-app && go run": "allow",
      "go test": "allow",
      "go run": "allow",
      "go build": "allow",
      "go mod": "allow"
    },
    "edit": {
      "notes-app/server/**/*.go": "allow",
      "notes-app/web/**/*": "allow",
      "notes-app/RULES.md": "allow"
    },
    "read": "allow"
  }
}
